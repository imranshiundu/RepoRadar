# Copy this file to .env for local development.
# Do not commit your real secrets.

PORT=3000
GROQ_API_KEY=replace_with_rotated_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional but recommended for higher GitHub rate limits.
GITHUB_TOKEN=

# Optional. If omitted, Product Hunt is skipped gracefully.
PRODUCT_HUNT_BEARER_TOKEN=
